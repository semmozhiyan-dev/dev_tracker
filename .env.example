# ============================================================================
# DevTrackr Environment Configuration Template
# ============================================================================
#
# IMPORTANT SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and fill in your actual values
# 3. NEVER commit the real .env file to version control (it's in .gitignore)
# 4. The app will fail to start if required variables are missing
#
# ============================================================================

# REQUIRED: GitHub Configuration
# ============================================================================

# Your GitHub username (e.g., octocat)
# Used to fetch your public events and commit history
GITHUB_USERNAME=your-github-username

# GitHub Personal Access Token for API authentication
# Create one at: https://github.com/settings/tokens
# Required minimum scopes:
#   - public_repo (allows reading public repositories)
#   - read:user (allows reading user profile data)
# Documentation: https://docs.github.com/en/authentication/keeping-your-account-and-data-secure/creating-a-personal-access-token
GITHUB_TOKEN=ghp_your_personal_access_token_here

# ============================================================================
# OPTIONAL: Advanced Configuration
# ============================================================================

# GitHub API Base URL (defaults to https://api.github.com)
# Only change this if you're using GitHub Enterprise with a custom API endpoint
# GITHUB_API_BASE=https://api.github.com

# Database Configuration (defaults to local SQLite)
# Supported formats:
#   - SQLite (local):     sqlite:///./devtrackr.db
#   - PostgreSQL:         postgresql://user:password@localhost:5432/devtrackr
#   - MySQL:              mysql+pymysql://user:password@localhost:3306/devtrackr
#   - SQL Server:         mssql+pyodbc://user:password@server/devtrackr?driver=ODBC+Driver+17+for+SQL+Server
#
# DATABASE_URL=sqlite:///./devtrackr.db

# ============================================================================
# Environment Validation
# ============================================================================
#
# When the application starts, it will automatically validate:
# ✓ GITHUB_USERNAME is set and not empty
# ✓ GITHUB_TOKEN is set and not empty
#
# If any required variable is missing, the app will:
# 1. Display a clear error message showing what's missing
# 2. Exit with a configuration error
# 3. NOT start the server
#
# To debug configuration issues:
# 1. Run: python -c "from app.config import GITHUB_USERNAME; print(GITHUB_USERNAME)"
# 2. Check the console output for validation error messages
# 3. Verify your .env file values are correct
#
# ============================================================================
# DATABASE_URL=sqlite:///./devtrackr.db
